#include <iostream>
#include <vector>
#include <algorithm>
int main() {
    int n;
    int s = 0;
    int cnt = 0;
    int tot;
    std::cout << "Enter the size of the array A: ";
    std::cin >> n;
    std::vector<int> arr(n);
    std::cout << "Enter the total time hours available: ";
    std::cin >> tot;
    std::cout << "Enter the elements in the array: ";
    for(int i = 0; i < n; i++) {
        std::cin >> arr[i];
    }
    std::sort(arr.begin(), arr.end());
    for(int k = 0; k < n; k++) {
        if (s + arr[k] > tot) {
            break; 
        }
        s = s + arr[k];
        cnt++;
    }
    std::cout << "Maximum books Alex can read: " << cnt << std::endl;
    return 0;
}
