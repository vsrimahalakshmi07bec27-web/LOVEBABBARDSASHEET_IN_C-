class Solution {
  public:
    double medianOf2(vector<int>& a, vector<int>& b) {
       a.insert(a.end(),b.begin(),b.end());
       sort(a.begin(),a.end());
       int n=a.size();
       if(n%2 !=0)
       return a[n/2];
       else
       {
           double k=(a[(n/2)-1]+a[n/2])/2.0;
           return k;
       }}
};
