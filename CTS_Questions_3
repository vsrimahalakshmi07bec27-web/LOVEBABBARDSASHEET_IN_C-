) #include <iostream>
#include <vector>
#include <cmath>
#include <numeric>
using namespace std; 
int main()
{
    int temp;
    int arr[100];
    int n,k;
    cout<<"enter the number of elements in an array"<<endl;
    cin>>n;
    cout<<"enter how many element you shoudl add to get the minimum"<<endl;
    cin>>k;
    for(int k=0;k<n;k++){
        
        cin>>arr[k];
    }
    int s = 0;
    bool swapped = true;
    int pass = 0;
    while (swapped) {
        swapped = false;
        for (int i = 0; i < n - 1 - pass; i++) {
            if (arr[i] > arr[i + 1]) {
                temp = arr[i + 1];
                arr[i + 1] = arr[i];
                arr[i] = temp;
                swapped = true;
            }
        }
        pass++; 
    }

    for (int m = 0; m < k; m++) {
        s = s + arr[m]; 
    }
    cout<<"the minimum sum is :"<<s;
    return 0;
}
