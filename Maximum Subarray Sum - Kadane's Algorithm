class Solution {
  public:
    int maxSubarraySum(vector<int> &arr) {
 //code here
    int res=arr[0];
  	for(int i=0;i<arr.size();i++){
    	int cur=0;
        for(int j=i;j<arr.size();j++){
        	cur=cur+arr[j];
            res=max(res, cur);
        }
    }
    return res;

  
    }
};
