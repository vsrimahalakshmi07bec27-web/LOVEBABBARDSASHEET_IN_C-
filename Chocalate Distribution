class Solution {
public:
    int findMinDiff(vector<int>& a, int m) {
        int n=a.size();
        sort(a.begin(),a.end());
        int mini=a[m-1]-a[0];
        for (int i=1;i+m-1<n;i++) {
            int current_diff=a[i+m-1]-a[i];
               if (current_diff<mini){
                mini=current_diff;
            }
        }
        return mini;
    }
};
