class Solution {
  public:
    int inversionCount(vector<int> &arr) {
        // Code Here
        int cnt=0;
        for(int i=0;i<arr.size();i++){
            for(int j=i;j<arr.size();j++){
                if(arr[i]>arr[j]){
                    cnt++;
                }
            }
        }
    return cnt;
    }
};
