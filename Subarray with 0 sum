class Solution {
public:
    bool subArrayExists(vector<int>& arr) {
        int n=arr.size();
        for (int i=0;i<n;i++) {
            int s=0; 
            for (int j=i;j<n;j++) {
                s+=arr[j];
                if(s==0) {
                    return true;
                }
            }
        }
        return false;
    }
};
