#include<iostream>
#include<string>
#include<algorithm>
using namespace std;
#define MAX 30005
class Solution {
public:
int top=-1;
int arr[MAX];
void push(int a){
if(top<MAX-1){
top++;
arr[top]=a;
}
}
void pop(){
if(top!=-1) top--;
}
int longestValidParentheses(string s){
top=-1;
push(-1);
int maxL=0;
for(int i=0;i<s.size();i++){
if(s[i]=='('){
push(i);
}else{
pop();
if(top==-1){
push(i);
}else{
maxL=max(maxL,i-arr[top]);
}
}
}
return maxL;
}
};
