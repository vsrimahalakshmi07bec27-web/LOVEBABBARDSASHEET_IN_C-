class Solution {
public:
    int minCost(string colors, vector<int>& neededTime) {
    int n=colors.size();
    int s=0;
    for(int i=0;i<n-1;i++){
        if(colors[i]==colors[i+1])
        {
            if(neededTime[i]>neededTime[i+1])
s=s+neededTime[i+1];
else if(neededTime[i]<neededTime[i+1])
s=s+neededTime[i];
        }
    }
    return s;
    }
};
