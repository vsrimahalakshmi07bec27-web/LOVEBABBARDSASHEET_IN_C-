class Solution {
  public:
    bool twoSum(vector<int>& arr, int target) {
        sort(arr.begin(), arr.end());
        int l = 0;
        int n = arr.size();
        int r = n - 1;
        while(l < r) {
            int currentSum = arr[l] + arr[r];
            if(currentSum == target) 
                return true;
            if(currentSum < target)
                l++; 
            else
                r--;
        }
        return false;
    }
};

