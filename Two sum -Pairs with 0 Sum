class Solution {
  public:
    vector<vector<int>> getPairs(vector<int>& arr) {
        vector<vector<int>> p;
        int n=arr.size();
        sort(arr.begin(),arr.end()); 
        for(int i=0;i<n;i++){
            if(i>0&&arr[i]==arr[i-1]) continue; 
            for(int j=i+1;j<n;j++){
                if(j>i+1&&arr[j]==arr[j-1]) continue;
                if(arr[i]+arr[j]==0){
                    if(arr[i]<arr[j]){
                        p.push_back({arr[i],arr[j]});
                    }
                    else{
                        p.push_back({arr[j],arr[i]});
                    }
                }
            }
        }
        return p;
    }
};
//optimized code
#include <vector>
using namespace std;
class Solution {
public:
    vector<vector<int>> getPairs(vector<int>& arr) {
        vector<vector<int>> result;
        int n=arr.size();
        if (n<2) return result;
        sort(arr.begin(),arr.end());
        int left=0;
        int right=n-1;
while (left<right) 
{
            int sum=arr[left]+arr[right];
            if(sum==0)
            {
                result.push_back({arr[left],arr[right]});
                while (left<right&&arr[left]==arr[left +1])left++;
                while (left<right&&arr[right]==arr[right-1])right--;
                left++;
                right--;
            } else if (sum<0) {
                left++; 
            } else {
                right--;
            }
        }
        return result;
    }
};

